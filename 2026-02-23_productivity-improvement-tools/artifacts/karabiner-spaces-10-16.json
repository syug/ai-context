{
    "title": "Switch to Desktops 10-16 (Karabiner Fallback)",
    "rules": [
        {
            "description": "Ctrl+0 → Desktop 10, Ctrl+Shift+1-6 → Desktops 11-16 (via Mission Control key simulation)",
            "manipulators": [
                {
                    "type": "basic",
                    "description": "Ctrl+0 → Desktop 10 (go to Desktop 1, then right 9 times)",
                    "from": {
                        "key_code": "0",
                        "modifiers": {
                            "mandatory": ["control"],
                            "optional": []
                        }
                    },
                    "to": [
                        {
                            "shell_command": "/Users/saitshug/scripts/switch-to-space.sh 10 &"
                        }
                    ]
                },
                {
                    "type": "basic",
                    "description": "Ctrl+Shift+1 → Desktop 11",
